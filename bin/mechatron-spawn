#!/opt/homebrew/bin/node
'use strict';
// mechatron-spawn — Sub-agent spawner with full safeguards
// Called by the parent agent when it needs to delegate focused sub-tasks.
//
// Usage:
//   mechatron-spawn <workspace> <task-json>
//
// task-json format:
//   {"tasks": [{"id": "t1", "instruction": "Research X"}, {"id": "t2", "instruction": "Write Y"}]}
//
// Or single task:
//   mechatron-spawn <workspace> "<instruction>"
//
// Safeguards (歯止め対策):
//   - maxDepth: 1 (sub-agents CANNOT spawn further sub-agents)
//   - maxConcurrent: 3 (max parallel sub-agents)
//   - maxChildrenPerCall: 3 (max tasks per invocation)
//   - timeoutSeconds: 60 per sub-agent
//   - Parent-close propagation (children die when parent dies)
//   - No auto-retry on failure
//   - Structured JSON result envelope

const { spawn, execFileSync } = require('child_process');
const fs = require('fs');
const path = require('path');

const HOME = process.env.HOME || '/Users/jayden.csai';
const MECHATRON   = path.join(HOME, 'bin/mechatron');
const MEM0_PYTHON = path.join(HOME, 'claude-agent/mem0-env/bin/python');
const MEM0_DIR    = path.join(HOME, 'claude-agent/mem0');

function getStandingInstructions() {
  try {
    const raw = execFileSync(
      MEM0_PYTHON,
      [path.join(MEM0_DIR, 'all.py')],
      {
        timeout: 20_000,
        encoding: 'utf-8',
        env: { ...process.env, HOME, PATH: `${HOME}/bin:/opt/homebrew/opt/node/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin` },
      }
    ).trim();
    const match = raw.match(/## Standing Instructions\n([\s\S]*?)(?=\n## |\n---|\n# [^#]|$)/);
    if (match) {
      const lines = match[1].trim();
      if (lines && !lines.startsWith('(none)')) return lines;
    }
  } catch {}
  return null;
}

// ── Safeguard constants ──────────────────────────────────────────────────
const MAX_DEPTH = 1;
const MAX_CONCURRENT = 3;
const MAX_CHILDREN_PER_CALL = 3;
const TIMEOUT_MS = 60000;   // 60 seconds per sub-agent
const STALL_DETECT_MS = 30000; // kill if no output for 30s

// ── Depth check ──────────────────────────────────────────────────────────
const currentDepth = parseInt(process.env.MECHATRON_SPAWN_DEPTH || '0');
if (currentDepth >= MAX_DEPTH) {
  console.error(`[mechatron-spawn] BLOCKED: depth ${currentDepth} >= max ${MAX_DEPTH}. Sub-agents cannot spawn sub-agents.`);
  console.log(JSON.stringify({
    status: 'forbidden',
    error: `Spawn depth ${currentDepth} exceeds maximum ${MAX_DEPTH}`,
    results: []
  }));
  process.exit(1);
}

// ── Parse args ───────────────────────────────────────────────────────────
const WORKSPACE = process.argv[2];
const taskArg = process.argv[3];

if (!WORKSPACE || !taskArg) {
  console.error('Usage: mechatron-spawn <workspace> \'{"tasks":[{"id":"t1","instruction":"..."}]}\' OR mechatron-spawn <workspace> "<instruction>"');
  process.exit(1);
}

let tasks;
try {
  const parsed = JSON.parse(taskArg);
  tasks = parsed.tasks || [{ id: 'single', instruction: taskArg }];
} catch {
  // Single string instruction
  tasks = [{ id: 'single', instruction: taskArg }];
}

// ── Children limit ───────────────────────────────────────────────────────
if (tasks.length > MAX_CHILDREN_PER_CALL) {
  console.error(`[mechatron-spawn] WARNING: ${tasks.length} tasks exceeds max ${MAX_CHILDREN_PER_CALL}. Truncating.`);
  tasks = tasks.slice(0, MAX_CHILDREN_PER_CALL);
}

function log(msg) {
  process.stderr.write(`[mechatron-spawn] ${new Date().toISOString()} ${msg}\n`);
}

// ── Run single sub-agent ─────────────────────────────────────────────────
function runSubAgent(task) {
  return new Promise((resolve) => {
    const startTime = Date.now();
    const taskId = task.id || 'unknown';

    const systemSuffix = `You are a focused sub-agent. Your ONLY job is to complete this specific task and return the result. Do NOT have a conversation. Do NOT read workspace files unless needed for the task. Be concise.`;

    const standingInstructions = getStandingInstructions();
    const prompt = `${standingInstructions ? '## Active Standing Instructions (from Vanessa\'s memory)\n' + standingInstructions + '\n\n---\n\n' : ''}${systemSuffix}\n\nTask: ${task.instruction}`;

    const args = [
      '--workspace', path.resolve(WORKSPACE),
      '--task', 'general',
      '--fresh',
      '--minimal',
      '--no-live-state',
      '--no-memory',
      '--no-mcp',
      '-p', prompt,
      '--model', 'claude-sonnet-4-6',
      '--max-turns', '10',
      '--output-format', 'text',
      '--dangerously-skip-permissions',
    ];

    log(`Starting sub-agent: ${taskId} — ${task.instruction.slice(0, 80)}`);

    const child = spawn(MECHATRON, args, {
      stdio: ['ignore', 'pipe', 'pipe'],
      env: {
        ...process.env,
        MECHATRON_SPAWN_DEPTH: String(currentDepth + 1),
        PATH: `${HOME}/bin:/opt/homebrew/bin:/opt/homebrew/opt/node/bin:/usr/local/bin:/usr/bin:/bin`,
        HOME,
      },
    });

    let stdout = '';
    let stderr = '';
    let lastOutputTime = Date.now();

    child.stdout.on('data', d => {
      stdout += d.toString();
      lastOutputTime = Date.now();
    });
    child.stderr.on('data', d => {
      stderr += d.toString();
    });

    // Timeout
    const timer = setTimeout(() => {
      log(`TIMEOUT: ${taskId} (${TIMEOUT_MS / 1000}s)`);
      child.kill('SIGTERM');
      setTimeout(() => { try { child.kill('SIGKILL'); } catch {} }, 5000);
    }, TIMEOUT_MS);

    // Stall detection
    const stallChecker = setInterval(() => {
      if (Date.now() - lastOutputTime > STALL_DETECT_MS) {
        log(`STALL: ${taskId} — no output for ${STALL_DETECT_MS / 1000}s`);
        child.kill('SIGTERM');
        clearInterval(stallChecker);
      }
    }, 5000);

    child.on('close', (code) => {
      clearTimeout(timer);
      clearInterval(stallChecker);
      const durationMs = Date.now() - startTime;

      const result = {
        id: taskId,
        status: code === 0 ? 'ok' : (code === null ? 'timeout' : 'failed'),
        exitCode: code,
        output: stdout.trim() || '[No output]',
        durationMs,
        instruction: task.instruction.slice(0, 100),
      };

      if (code !== 0) {
        result.error = stderr.slice(0, 300) || `Exit code ${code}`;
      }

      log(`Completed: ${taskId} — ${result.status} (${durationMs}ms)`);
      resolve(result);
    });

    child.on('error', (err) => {
      clearTimeout(timer);
      clearInterval(stallChecker);
      resolve({
        id: taskId,
        status: 'error',
        error: err.message,
        output: '[Process error]',
        durationMs: Date.now() - startTime,
        instruction: task.instruction.slice(0, 100),
      });
    });
  });
}

// ── Run all tasks (sequential by default) ────────────────────────────────
async function main() {
  const isParallel = process.argv.includes('--parallel');
  log(`Running ${tasks.length} tasks (${isParallel ? 'parallel' : 'sequential'}, depth: ${currentDepth + 1}, max concurrent: ${MAX_CONCURRENT})`);

  // Track child PIDs for parent-close propagation
  const childPids = [];
  process.on('SIGTERM', () => {
    log('Parent killed — terminating all children');
    childPids.forEach(pid => { try { process.kill(pid, 'SIGTERM'); } catch {} });
    process.exit(1);
  });
  process.on('SIGINT', () => {
    log('Parent interrupted — terminating all children');
    childPids.forEach(pid => { try { process.kill(pid, 'SIGTERM'); } catch {} });
    process.exit(1);
  });

  let results;

  if (isParallel && tasks.length > 1) {
    // Parallel with concurrency limit
    const chunks = [];
    for (let i = 0; i < tasks.length; i += MAX_CONCURRENT) {
      chunks.push(tasks.slice(i, i + MAX_CONCURRENT));
    }
    results = [];
    for (const chunk of chunks) {
      const chunkResults = await Promise.all(chunk.map(t => runSubAgent(t)));
      results.push(...chunkResults);
    }
  } else {
    // Sequential
    results = [];
    for (const task of tasks) {
      results.push(await runSubAgent(task));
    }
  }

  // Output structured envelope
  const envelope = {
    status: results.every(r => r.status === 'ok') ? 'all_ok' : 'partial',
    totalTasks: tasks.length,
    succeeded: results.filter(r => r.status === 'ok').length,
    failed: results.filter(r => r.status !== 'ok').length,
    results,
  };

  console.log(JSON.stringify(envelope, null, 2));
}

main().catch(e => {
  log(`FATAL: ${e.message}`);
  console.log(JSON.stringify({ status: 'error', error: e.message, results: [] }));
  process.exit(1);
});
