#!/opt/homebrew/bin/node
'use strict';
// salvage-tools — On-demand MCP tool execution
// Called by the agent when it needs to use an external tool (Notion, n8n, Slack, etc.)
// Runs a one-shot salvage call WITH MCP servers loaded.
//
// Usage:
//   salvage-tools <workspace> "<instruction>"
//
// Examples:
//   salvage-tools ~/clawd "Read the Notion page for RENPHO project status"
//   salvage-tools ~/clawd "List active n8n workflows"
//   salvage-tools ~/clawd "Search Slack #mgc-all for messages about Komatsu from today"
//   salvage-tools ~/clawd "Deploy the latest commit on Vercel project komatsu-deploy"
//
// Concurrency:
//   Uses salvage-db mcp-claim to atomically acquire a running slot (max 5).
//   If all slots are taken, this process exits with a structured JSON "queued" response
//   and touches ~/.salvage/dispatch-signal to wake the poller.
//   The poller will later run the instruction via mcp-next + salvage-tools.
//
// When spawned by the poller (SALVAGE_FROM_POLLER=1 + SALVAGE_SLOT_ID=<id>):
//   Skips the mcp-claim step entirely — slot is already claimed by the poller.

const { spawn, execFileSync } = require('child_process');
const path = require('path');
const fs = require('fs');

const HOME = process.env.HOME || '/Users/jayden.csai';
const SALVAGE    = path.join(HOME, 'bin/salvage');
const DB_CMD       = path.join(HOME, 'bin/salvage-db');
const MEM0_PYTHON  = path.join(HOME, 'claude-agent/mem0-env/bin/python');
const MEM0_DIR     = path.join(HOME, 'claude-agent/mem0');
const SIGNAL_FILE  = path.join(HOME, '.salvage/dispatch-signal');

function getStandingInstructions() {
  try {
    const raw = execFileSync(
      MEM0_PYTHON,
      [path.join(MEM0_DIR, 'all.py')],
      {
        timeout: 20_000,
        encoding: 'utf-8',
        env: { ...process.env, HOME, PATH: `${HOME}/bin:/opt/homebrew/opt/node/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin` },
      }
    ).trim();
    const match = raw.match(/## Standing Instructions\n([\s\S]*?)(?=\n## |\n---|\n# [^#]|$)/);
    if (match) {
      const lines = match[1].trim();
      if (lines && !lines.startsWith('(none)')) return lines;
    }
  } catch {}
  return null;
}

function dbExec(args) {
  return execFileSync(DB_CMD, args, {
    timeout: 10_000,
    encoding: 'utf-8',
    env: { ...process.env, HOME, PATH: `${HOME}/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin` },
  }).trim();
}

const WORKSPACE   = process.argv[2];
const INSTRUCTION = process.argv[3];

if (!WORKSPACE || !INSTRUCTION) {
  console.error('Usage: salvage-tools <workspace> "<instruction>"');
  console.error('');
  console.error('Examples:');
  console.error('  salvage-tools ~/clawd "Read Notion page for RENPHO"');
  console.error('  salvage-tools ~/clawd "List n8n workflows"');
  console.error('  salvage-tools ~/clawd "Post to Slack #mgc-all: meeting at 3pm"');
  process.exit(1);
}

const TIMEOUT_MS = 120_000; // 2 min max for a tool call

// ── Concurrency gate (SQLite mcp_slots) ──────────────────────────────────
// When spawned by the poller, the slot is already claimed — skip mcp-claim.
const FROM_POLLER = !!process.env.SALVAGE_FROM_POLLER;
let slotId = process.env.SALVAGE_SLOT_ID || null;

if (!FROM_POLLER) {
  // Atomic slot claim: running (under limit) or queued (over limit).
  let claimResult;
  try {
    claimResult = dbExec(['mcp-claim', String(process.pid), INSTRUCTION.slice(0, 200), path.resolve(WORKSPACE)]);
  } catch (e) {
    // DB unavailable — log warning and proceed untracked (don't block the tool call)
    console.error(`[salvage-tools] WARNING: mcp-claim failed (DB unavailable?): ${e.message}`);
    claimResult = `running|fallback-${process.pid}`;
  }

  const pipeIdx = claimResult.indexOf('|');
  const claimStatus = claimResult.slice(0, pipeIdx);
  slotId = claimResult.slice(pipeIdx + 1);

  if (claimStatus === 'queued') {
    // Over the concurrency limit. Wake the poller and return structured response.
    try {
      fs.mkdirSync(path.dirname(SIGNAL_FILE), { recursive: true });
      fs.writeFileSync(SIGNAL_FILE, String(Date.now()));
    } catch {}

    console.log(JSON.stringify({
      status: 'queued',
      slot_id: slotId,
      message: 'Tool call queued — MCP concurrency limit reached. The poller will execute this shortly.',
      instruction: INSTRUCTION.slice(0, 100),
    }));
    process.exit(0);
  }
  // claimStatus === 'running' — we have a slot, proceed immediately.
}

// Release slot on completion (success or failure).
// Called from child.on('close') — not process.on('exit') — so we can pass the result.
function releaseSlot(success, resultOrError) {
  if (!slotId || slotId.startsWith('fallback-')) return;
  try {
    if (success) {
      dbExec(['mcp-done', slotId, (resultOrError || '').slice(0, 2000)]);
    } else {
      dbExec(['mcp-failed', slotId, (resultOrError || '').slice(0, 500)]);
    }
  } catch (e) {
    console.error(`[salvage-tools] WARNING: slot release failed: ${e.message}`);
  }
}

// Ensure slot is marked failed if process exits unexpectedly (SIGKILL can't be caught,
// but mcp-recover handles that case on the poller side).
process.on('SIGTERM', () => {
  releaseSlot(false, 'SIGTERM received');
  process.exit(1);
});
process.on('SIGINT', () => {
  releaseSlot(false, 'SIGINT received');
  process.exit(1);
});

// System prompt suffix to keep the sub-agent focused
const standingInstructions = getStandingInstructions();
const TOOL_INSTRUCTION = `${standingInstructions ? '## Active Standing Instructions (from Vanessa\'s memory)\n' + standingInstructions + '\n\n---\n\n' : ''}You are a tool execution sub-agent. Your ONLY job:
1. Execute the requested tool operation
2. Return the result as concise text
Do NOT have a conversation. Do NOT read workspace files. Do NOT use the read tool on SKILL.md files.
Just execute the tool and return the result. Be brief.

Task: ${INSTRUCTION}`;

const args = [
  '--workspace', path.resolve(WORKSPACE),
  '--task', 'general',
  '--fresh',
  '--minimal',
  '--no-live-state',
  '--no-memory',
  '-p', TOOL_INSTRUCTION,
  '--model', 'claude-sonnet-4-6',
  '--max-turns', '10',
  '--output-format', 'text',
  '--dangerously-skip-permissions',
];

// Remove --no-mcp for this call (we WANT MCP here)
// salvage will load MCP because --no-mcp is not in args and --minimal doesn't skip MCP

const child = spawn(SALVAGE, args, {
  stdio: ['ignore', 'pipe', 'pipe'],
  env: {
    ...process.env,
    PATH: `${HOME}/bin:/opt/homebrew/bin:/opt/homebrew/opt/node/bin:/usr/local/bin:/usr/bin:/bin`,
    HOME,
  },
});

let stdout = '';
let stderr = '';
child.stdout.on('data', d => stdout += d);
child.stderr.on('data', d => stderr += d);

const timer = setTimeout(() => {
  // Kill the entire process group so claude grandchildren don't orphan.
  try { process.kill(-child.pid, 'SIGTERM'); } catch { child.kill('SIGTERM'); }
  setTimeout(() => {
    try { process.kill(-child.pid, 'SIGKILL'); } catch { try { child.kill('SIGKILL'); } catch {} }
  }, 5000);
  console.error('[salvage-tools] Timed out after ' + (TIMEOUT_MS / 1000) + 's');
  releaseSlot(false, 'Execution timed out after ' + (TIMEOUT_MS / 1000) + 's');
  console.log('[TIMEOUT] Tool execution timed out. The MCP servers may be slow to start.');
  process.exit(1);
}, TIMEOUT_MS);

child.on('close', code => {
  clearTimeout(timer);
  if (code !== 0) {
    process.stderr.write(`[salvage-tools] Exit code ${code}\n`);
    if (stderr) process.stderr.write(stderr.slice(0, 500) + '\n');
  }
  const output = stdout.trim() || '[No output from tool execution]';
  releaseSlot(code === 0, code === 0 ? output : `Exit code ${code}: ${stderr.slice(0, 200)}`);
  console.log(output);
  process.exit(code || 0);
});

child.on('error', err => {
  clearTimeout(timer);
  console.error(`[salvage-tools] Error: ${err.message}`);
  releaseSlot(false, err.message);
  process.exit(1);
});
