# Secrets — never commit
.env
.env.local
*.key
*.pem
**/credentials.json
**/oauth-token.json
**/.claude-setup-token
# Real mcp-config (has tokens) — only example is tracked
config/mcp-config.json
# OpenClaw secrets/identity
.openclaw/secrets/
.openclaw/credentials/
.openclaw/identity/
.openclaw/devices/

# Runtime / generated state
logs/
*.log
sessions/
state/
.DS_Store
*.wal
*.shm
mem0-env/
prompts/

# Memory — regenerated by mechatron-ingest; too large and personal for git
memory/ingested/

# SQLite databases (binary, large, always changing)
*.sqlite
*.db

# Node
node_modules/
package-lock.json

# macOS
.DS_Store
__MACOSX/

# IDE
.vscode/
.idea/
*.swp
*.swo
